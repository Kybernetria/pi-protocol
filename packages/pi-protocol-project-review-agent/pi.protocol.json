{
  "protocolVersion": "0.2.0",
  "nodeId": "project_review_agent",
  "packageId": "@kyvernitria/pi-protocol-project-review-agent",
  "version": "0.0.0-prototype",
  "purpose": "Project/task review agent.",
  "agents": {
    "project_reviewer": {
      "description": "Concise project/task reviewer.",
      "systemPrompt": {
        "text": "Review tasks concisely.",
        "mode": "append"
      }
    }
  },
  "ui": {
    "agentColors": {
      "root_agent": "accent",
      "project_reviewer": "success",
      "pi-chat": "accent"
    }
  },
  "provides": [
    {
      "name": "review_task",
      "description": "Review a project task.",
      "inputSchema": {
        "type": "string"
      },
      "outputSchema": {
        "type": "string"
      },
      "execution": {
        "type": "agent",
        "agent": "project_reviewer"
      }
    }
  ]
}
